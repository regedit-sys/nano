# Database Settings
DATABASE_TYPE=json                       # Database type: 'json' or 'postgres'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poprink_nano # Connection string (only for postgres)

# TMDB Media API
TMDB_API_KEY=                           # TMDB API v3 Key
TMDB_ACCESS_TOKEN=                      # TMDB API Read Access Token

# Visual Theme
THEME_HUE=92                            # Base color hue (0 to 360)
THEME_MODE=dark                          # Default theme mode: 'dark' or 'light'
COLOR_BG_DARK=#16161a                    # Dark mode background color
COLOR_BG_LIGHT=#f8f9fa                   # Light mode background color
THEME_BG_STYLE=none                      # Background pattern: dots, lines, thin-lines, text, grain, none
THEME_CUSTOM_BG=                         # Custom background image URL or path

# Logo and Slogans
SITE_NAME=poprink                        # Site name used in title and logo
SHOW_ICON=false                          # Show icon in logo: true/false
USE_MIXED_FANCY_FONT=true                # Mix decorative fonts in logo: true/false
LOGO_SIZE=lg                             # Size of logo: sm, md, lg, xl
SHOW_GREETING=true                       # Show slogans under search: true/false
GREETING_STYLE=                          # Style: slogans, logo, icon, gif, logo-and-icon (leave blank for auto)
CUSTOM_ICON=                             # Custom icon map key (e.g., tv, film, gamepad)
CUSTOM_GIF=                              # Path or URL to custom GIF image
CUSTOM_GIF_WIDTH=                        # Custom width for the GIF (e.g. 140px)
CUSTOM_GIF_HEIGHT=                       # Custom height for the GIF (e.g. 140px)
CUSTOM_GIF_MARGIN=                       # Custom margins/position for the GIF (e.g. 0px auto 20px auto)

# SEO Metadata
METADATA_TITLE=poprink nano              # SEO website title
METADATA_DESCRIPTION=a minimalist web interface for poprink. search for movies and tv shows instantly without bloat. # SEO website description
METADATA_THUMBNAIL=/icons/poprink.svg    # SEO social sharing preview image

# Preferences
DEFAULT_LOCALE=en                        # Default site language (e.g., en, es, ar)
SHOW_WATERMARKS=true                     # Show decorative watermarks: true/false
SHOW_TRENDING=false                      # Show trending movies list: true/false
SHOW_QUICK_TAGS=false                    # Show search suggestion tags: true/false
ENABLE_AUTH=false                        # Enable login/signup system: true/false
ENABLE_CONTINUE_WATCHING=false           # Enable continue watching list: true/false
ENABLE_WATCHLIST=false                   # Enable personal watchlist: true/false
ENABLE_LOCAL_LIBRARY=false               # Enable local media library: true/false
ENABLE_LOCAL_LIBRARY_EDITING=false       # Enable adding/editing local library: true/false


# Header Buttons
HEADER_SHOW_THEME_TOGGLE=true            # Show theme switch: true/false
HEADER_SHOW_COLOR_PICKER=true            # Show color customization: true/false
HEADER_SHOW_LANG_SELECTOR=true           # Show language picker: true/false

# Video Player
AUTOPLAY=true                            # Auto-play player on load: true/false
DEFAULT_SERVER=vidzeeWorks               # Default stream source server key
USE_VIDSTACK=true                        # Use Vidstack player framework: true/false
LOGO_FONT_FAMILY=                        # Custom font family for logo when mixed fonts are disabled (e.g., Cairo, Amiri)
THEME_FONT_FAMILY=                       # Custom font family for the entire site (e.g., Outfit, Inter, Roboto)
