---
import NanoHome from '../components/poprink/NanoHome';
import { poprinkConfig } from '../components/poprink/config.poprink';

const user = Astro.cookies.get('user')?.value;
if (poprinkConfig.features.enableAuth && !user) {
  return Astro.redirect('/login');
}
---

<html lang={poprinkConfig.metadata.defaultLocale || 'en'} dir={(poprinkConfig.metadata.defaultLocale || 'en') === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <script is:inline define:vars={{ config: poprinkConfig }}>
      window.__POPRINK_CONFIG__ = config;
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/icons/poprink.svg" />
    <title>{poprinkConfig.metadata.title}</title>
    <meta name="description" content={poprinkConfig.metadata.description} />
    <meta property="og:title" content={poprinkConfig.metadata.title} />
    <meta property="og:description" content={poprinkConfig.metadata.description} />
    <meta property="og:image" content={poprinkConfig.metadata.thumbnail} />
    <script is:inline define:vars={{ defaultTheme: poprinkConfig.theme.defaultMode, defaultHue: poprinkConfig.theme.defaultHue }}>
      (function() {
        let theme = defaultTheme || 'dark';
        const savedTheme = localStorage.getItem('poprink-theme');
        if (savedTheme === 'dark' || savedTheme === 'light') {
          theme = savedTheme;
        }
        document.documentElement.setAttribute('data-theme', theme);
        
        let hue = defaultHue ? defaultHue.toString() : '310';
        const savedHue = localStorage.getItem('poprink-theme-hue');
        if (savedHue) {
          const parsed = parseInt(savedHue, 10);
          if (!isNaN(parsed) && parsed >= 0 && parsed <= 360) {
            hue = parsed.toString();
          }
        }
        document.documentElement.style.setProperty('--theme-hue', hue);
      })();
    </script>
  </head>
  <body style="margin: 0; background-color: var(--bg-color);">
    <NanoHome client:load initialUser={user} />
  </body>
</html>
